# Copy this file to .env.local and fill in the values from your Supabase
# project. See SUPABASE_SETUP.md for step-by-step instructions.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — NEVER expose this key to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Origin used to build magic-link redirect URLs. Use http://localhost:3000
# for local dev; in Vercel set this to your production URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
